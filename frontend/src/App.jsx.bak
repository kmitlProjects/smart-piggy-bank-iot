import { useState, useEffect } from 'react'
import mqtt from 'mqtt'
import './App.css'

function App() {
  const [coins, setCoins] = useState({ '10': 0, '5': 0, '2': 0, '1': 0 })
  const [total, setTotal] = useState(0)
  const [distance, setDistance] = useState(null)
  const [fillPercent, setFillPercent] = useState(0)
  const [isLocked, setIsLocked] = useState(true)
  const [wifiConnected, setWifiConnected] = useState(false)
  const [isMqttConnected, setIsMqttConnected] = useState(false)

  // Connect to MQTT on component mount
  useEffect(() => {
    // WebSocket URL for HiveMQ Cloud
    const client = mqtt.connect('wss://broker.hivemq.com:8884/mqtt', {
      clientId: 'piggybank_frontend_' + Math.random().toString(16).slice(2),
    })

    client.on('connect', () => {
      console.log('✓ MQTT Connected')
      setIsMqttConnected(true)
      // Subscribe to piggy bank data topic
      client.subscribe('piggybank/data', (err) => {
        if (err) console.error('Subscribe error:', err)
      })
    })

    client.on('message', (topic, message) => {
      try {
        const data = JSON.parse(message.toString())
        console.log('📨 Received:', data)

        // Update coins data
        if (data.coins) {
          setCoins(data.coins)
        }

        // Update status
        if (data.distance_cm !== undefined) {
          setDistance(data.distance_cm)
        }
        if (data.fill_percent !== undefined) {
          setFillPercent(data.fill_percent)
        }
        if (data.is_locked !== undefined) {
          setIsLocked(data.is_locked)
        }
        if (data.wifi_connected !== undefined) {
          setWifiConnected(data.wifi_connected)
        }
      } catch (error) {
        console.error('Failed to parse message:', error)
      }
    })

    client.on('disconnect', () => {
      console.log('✗ MQTT Disconnected')
      setIsMqttConnected(false)
    })

    client.on('error', (err) => {
      console.error('MQTT Error:', err)
    })

    return () => {
      client.end()
    }
  }, [])

  // Calculate total
  useEffect(() => {
    const totalCoin =
      coins['10'] * 10 +
      coins['5'] * 5 +
      coins['2'] * 2 +
      coins['1'] * 1
    setTotal(totalCoin)
  }, [coins])

  return (
    <div className="container">
      <h1>🏦 Smart Piggy Bank</h1>
      <p style={{ color: '#888', marginBottom: '2rem' }}>Connected to MQTT ✅</p>

      <div className="coins-grid">
        {[
          { value: 10, baht: '10 บาท' },
          { value: 5, baht: '5 บาท' },
          { value: 2, baht: '2 บาท' },
          { value: 1, baht: '1 บาท' },
        ].map((coin) => (
          <div key={coin.value} className="coin-card">
            <div style={{ fontSize: '3rem', marginBottom: '0.5rem' }}>💰</div>
            <h3 style={{ fontSize: '1rem', marginBottom: '0.5rem' }}>{coin.baht}</h3>
            <p style={{ fontSize: '2rem', fontWeight: 'bold', color: '#10b981', margin: '0.5rem 0' }}>
              {coins[coin.value]}
            </p>
            <p style={{ fontSize: '0.9rem', color: '#888', margin: 0 }}>
              = {coin.value * coins[coin.value]} บาท
            </p>
          </div>
        ))}
      </div>

      <div className="total-box">
        <h2>รวมทั้งหมด</h2>
        <p className="total-amount">{total} บาท</p>
      </div>

      <div className="status-grid">
        <div className="status-item">
          <span className="label">WiFi</span>
          <span className="value">{wifiConnected ? '✅ Connected' : '❌ Offline'}</span>
        </div>
        <div className="status-item">
          <span className="label">Lock</span>
          <span className="value">{isLocked ? '🔒 Locked' : '🔓 Unlocked'}</span>
        </div>
        <div className="status-item">
          <span className="label">Fill</span>
          <span className="value">{fillPercent ? Math.round(fillPercent) : 0}%</span>
        </div>
        <div className="status-item">
          <span className="label">MQTT</span>
          <span className="value">{isMqttConnected ? '🟢 Live' : '🔴 Offline'}</span>
        </div>
      </div>
    </div>
  )
}

export default App;
