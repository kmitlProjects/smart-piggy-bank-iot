# Copy this file to backend/.env and edit values as needed.
# For local-only mode, run:
#   python tools/set_host.py --auto

# MQTT broker for backend subscriber
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC_DATA=piggybank/data
MQTT_CLIENT_ID=piggybank_backend_sub

# Flask API
API_HOST=127.0.0.1
API_PORT=5000

